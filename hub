local function SaveSettings()
    local success = pcall(function()
        local saveData = {}
        for key, value in pairs(settings) do
            saveData[key] = value
        end
        writefile("AimbotSettings.json", game:GetService("HttpService"):JSONEncode(saveData))
    end)
end

local function LoadSettings()
    local success, result = pcall(function()
        if isfile("AimbotSettings.json") then
            local data = readfile("AimbotSettings.json")
            local loaded = game:GetService("HttpService"):JSONDecode(data)
            for key, value in pairs(loaded) do
                settings[key] = value
            end
            
            -- Configurações padrão para novas opções
            if settings.PingToggleKey == nil then
                settings.PingToggleKey = DEFAULT_SETTINGS.PingToggleKey
            end
            if settings.InfiniteJumpKey == nil then
                settings.InfiniteJumpKey = DEFAULT_SETTINGS.InfiniteJumpKey
            end
            if settings.RejoinKey == nil then
                settings.RejoinKey = DEFAULT_SETTINGS.RejoinKey
            end
            if settings.AutoPrediction == nil then
                settings.AutoPrediction = DEFAULT_SETTINGS.AutoPrediction
            end
            if settings.Prediction == nil then
                settings.Prediction = 0.15  -- Valor padrão de predição
            end
            
            -- Aplicar configurações carregadas
            autoPredictionEnabled = settings.AutoPrediction
            
        else
            for key, value in pairs(DEFAULT_SETTINGS) do
                settings[key] = value
            end
            settings.Prediction = 0.15  -- Valor padrão de predição
            autoPredictionEnabled = settings.AutoPrediction
            SaveSettings()
        end
    end)
    
    if not success then
        for key, value in pairs(DEFAULT_SETTINGS) do
            settings[key] = value
        end
        settings.Prediction = 0.15
        autoPredictionEnabled = settings.AutoPrediction
        SaveSettings()
    end
end

local function makeMovable(frame)
    local dragToggle = false
    local dragStart = nil
    local startPos = nil
    
    
    local moveConnection, endConnection

    frame.Active = true
    frame.Selectable = true
    frame.Draggable = false 

    local function updateDrag(input)
        if not dragToggle or not dragStart or not startPos then return end
        
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y
        
  
        local viewportSize = workspace.CurrentCamera.ViewportSize
        local frameSize = frame.AbsoluteSize
        
        newX = math.clamp(newX, 0, viewportSize.X - frameSize.X)
        newY = math.clamp(newY, 0, viewportSize.Y - frameSize.Y)
        
        frame.Position = UDim2.new(0, newX, 0, newY)
    end

    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragToggle = true
            dragStart = input.Position
            startPos = frame.Position
            frame.ZIndex = 1000
            
            if moveConnection then moveConnection:Disconnect() end
            moveConnection = UserInputService.InputChanged:Connect(function(moveInput)
                if moveInput.UserInputType == Enum.UserInputType.MouseMovement then
                    updateDrag(moveInput)
                end
            end)
            
            
            if endConnection then endConnection:Disconnect() end
            endConnection = UserInputService.InputEnded:Connect(function(endInput)
                if endInput.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragToggle = false
                    frame.ZIndex = 1
                    
                    if moveConnection then
                        moveConnection:Disconnect()
                        moveConnection = nil
                    end
                    if endConnection then
                        endConnection:Disconnect()
                        endConnection = nil
                    end
                end
            end)
        end
    end

    local function cleanup()
        dragToggle = false
        if moveConnection then
            moveConnection:Disconnect()
            moveConnection = nil
        end
        if endConnection then
            endConnection:Disconnect()
            endConnection = nil
        end
    end

    
    local dragHandle = Instance.new("Frame")
    dragHandle.Name = "DragHandle"
    dragHandle.Size = UDim2.new(1, 0, 1, 0)
    dragHandle.Position = UDim2.new(0, 0, 0, 0)
    dragHandle.BackgroundTransparency = 1
    dragHandle.BorderSizePixel = 0
    dragHandle.ZIndex = frame.ZIndex + 1
    dragHandle.Parent = frame

   
    dragHandle.InputBegan:Connect(startDrag)
    frame.InputBegan:Connect(startDrag) 
    
    
    frame.AncestryChanged:Connect(function()
        if not frame.Parent then
            cleanup()
        end
    end)
end




local function processObject(obj, isNew)
    if not optimizationEnabled then return false end
    
    local name = obj.Name:lower()
    local className = obj.ClassName
    
    if obj:IsA("ParticleEmitter") and obj.Name == "smokeeffect" then
        removedCounts.smokeeffect += 1
        if isNew then task.wait() end
        pcall(obj.Destroy, obj)
        return true
    end

    if obj:IsA("Model") and obj.Name == "enemyclone" then
        local parent = obj.Parent
        if parent and parent.Name == "ClientEffects" then
            removedCounts.enemyclone += 1
            if isNew then task.wait() end
            pcall(obj.Destroy, obj)
            return true
        end
    end

    if obj:IsA("Model") then
        if string.find(name, "clone") or 
           string.find(name, "flicker") or 
           string.find(name, "statz") or
           string.find(name, "npc") then
            
            removedCounts.npc += 1
            if isNew then task.wait() end
            pcall(obj.Destroy, obj)
            return true
        end
    end
    
    if ToDisable.Parts and PartClasses[className] then
        pcall(function()
            obj.Material = Enum.Material.SmoothPlastic
            disabledCount += 1
        end)
        
    elseif ToDisable.Particles and ParticleClasses[className] then
        pcall(function()
            obj.Enabled = false
            disabledCount += 1
        end)
        
    elseif ToDisable.VisualEffects and VisualEffectClasses[className] then
        pcall(function()
            obj.Enabled = false
            disabledCount += 1
        end)
        
    elseif ToDisable.Textures and className == "Texture" then
        pcall(function()
            obj.Texture = ""
            disabledCount += 1
        end)
        
    elseif ToDisable.Sky and className == "Sky" then
        pcall(function()
            obj.Parent = nil
            disabledCount += 1
        end)
    end
    
    return false
end

local function startOptimization()
    if optimizationEnabled then return end
    
    optimizationEnabled = true
    local startTime = os.clock()
    local descendants = Workspace:GetDescendants()
    local total = #descendants
    
    for i = 1, total do
        processObject(descendants[i], false)
        
        if i % 500 == 0 then
            task.wait()
        end
    end
    
    local endTime = os.clock()
    
    print("SISTEMA DE OTIMIZACAO ATIVADO")
    print("Estatisticas de remocao:")
    print("   smokeeffect: " .. removedCounts.smokeeffect)
    print("   enemyclone: " .. removedCounts.enemyclone) 
    print("   NPCs: " .. removedCounts.npc)
    print("Estatisticas de otimizacao:")
    print("   Assets desabilitados: " .. disabledCount)
    print("Tempo total: " .. string.format("%.2f", endTime - startTime) .. " segundos")
    print("Objetos processados: " .. total)
    
    if ToEnable.FullBright then
        task.spawn(function()
            local Lighting = game:GetService("Lighting")
            
            local lightingProperties = {
                FogColor = Color3.fromRGB(255, 255, 255),
                FogEnd = math.huge,
                FogStart = math.huge,
                Ambient = Color3.fromRGB(255, 255, 255),
                Brightness = 5,
                ColorShift_Bottom = Color3.fromRGB(255, 255, 255),
                ColorShift_Top = Color3.fromRGB(255, 255, 255),
                OutdoorAmbient = Color3.fromRGB(255, 255, 255),
                Outlines = false
            }
            
            for property, value in pairs(lightingProperties) do
                pcall(function()
                    Lighting[property] = value
                end)
            end
            
            print("FullBright ativado")
        end)
    end
end

