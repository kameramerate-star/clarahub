UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end

  -- F2 para forçar refresh de todos os overlays
    if input.KeyCode == Enum.KeyCode.F2 then
        refreshAllOverlays()
    end

    
    if MatchesInputToKey(input, settings.GUIOpenKey) then
        ToggleGUI()
    end
    
    if MatchesInputToKey(input, settings.ToggleKey) then
        if settings.HoldMode then
            ToggleAimbot(true)
        else
            ToggleAimbot(not aimbotEnabled)
        end
    end
    
    if MatchesInputToKey(input, settings.PingToggleKey) then
        TogglePingDisplay()
    end
    
    if MatchesInputToKey(input, settings.InfiniteJumpKey) then
        toggleInfiniteJump()
    end

	 if MatchesInputToKey(input, settings.RejoinKey) then
        print("Rejoin executado pela tecla F10")
        executeRejoin()
    end
    
    if input.KeyCode == TOGGLE_KEY_ESP then
        if debounce then return end
        debounce = true
        toggleEspVisibility()
        task.delay(DEBOUNCE_KEY, function() debounce = false end)
        
    elseif input.KeyCode == TOGGLE_KEY_OVERLAY then
        if debounce then return end
        debounce = true
        toggleOverlayVisibility()
        task.delay(DEBOUNCE_KEY, function() debounce = false end)
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if gp then return end
    
    if settings.HoldMode and MatchesInputToKey(input, settings.ToggleKey) then
        ToggleAimbot(false)
    end
end)


local lastUpdate = 0
local updateInterval = 0.2
local lastCleanup = 0
local cleanupInterval = 5

local heartbeatConnection = RunService.Heartbeat:Connect(function()
    local now = tick()
    
    -- Fazer cleanup periódico
    if (now - lastCleanup) > cleanupInterval then
        cleanupInvalidOverlays()
        lastCleanup = now
    end
    
    if (now - lastUpdate) < updateInterval then return end
    lastUpdate = now
    
    -- Atualizar overlays de forma segura
    for player, _ in pairs(overlayList) do
        if player and player.Parent then
            updateOverlayForPlayer(player)
        else
            removeOverlayEntry(player)
        end
    end
end)


