local function IsVisible(part)
    if not settings.WallCheck then return true end
    if not part or not part.Position then return false end
    
    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    rayParams.IgnoreWater = true
    
    local result = Workspace:Raycast(origin, dir.Unit * dir.Magnitude, rayParams)
    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end
    return true
end

local lastTargetCheck = 0
local targetCheckInterval = 0.15

local function GetBestTarget()
    local now = tick()
    if (now - lastTargetCheck) < targetCheckInterval then
        return currentTarget and currentTarget.Parent and currentTarget or nil
    end
    lastTargetCheck = now
    
    if not Camera or not Camera.CFrame then return nil, nil end
    
    local camPos = Camera.CFrame.Position
    local camDir = Camera.CFrame.LookVector
    local bestPlayer, bestPart, bestScore = nil, nil, -1
    
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        if IsSquadMember(player) then continue end
        
        local part = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("UpperTorso") or player.Character:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        local dir = part.Position - camPos
        local dist = dir.Magnitude
        
        if dist > settings.MaxDistance then continue end
        
        local dot = camDir:Dot(dir.Unit)
        local angle = math.deg(math.acos(math.clamp(dot, -1, 1)))
        
        if angle > settings.FOV/2 then continue end
        
        if not IsVisible(part) then continue end
        
        local score = 0
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        local health = humanoid and (humanoid.Health / math.max(1, humanoid.MaxHealth)) or 1
        
        if settings.Priority == "Closest" then
            score = 1000 - dist - angle * 10
        elseif settings.Priority == "Crosshair" then
            score = 1000 - angle * 20
        elseif settings.Priority == "LowestHealth" then
            score = 1000 - (health * 500) - angle * 10
        end
        
        if score > bestScore then
            bestScore = score
            bestPlayer = player
            bestPart = part
        end
    end
    
    return bestPlayer, bestPart
end

local function SmoothLookAt(currentCFrame, targetPos, smooth)
    local desiredCFrame = CFrame.new(currentCFrame.Position, targetPos)
    
    if smooth <= 0 then return desiredCFrame end
    return currentCFrame:Lerp(desiredCFrame, math.clamp(smooth, 0, 1))
end

local function GetBrutalPrediction(targetPart, predictionMultiplier)
    if not targetPart or predictionMultiplier <= 0 or not targetPart.Parent then
        return targetPart.Position  -- Retorna posição atual sem predição
    end

    local character = targetPart.Parent
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return targetPart.Position end
    
    -- 1. VELOCIDADE ATUAL E HISTÓRICO
    local targetVelocity = rootPart.Velocity
    local targetSpeed = targetVelocity.Magnitude
    
    -- Inicializar histórico para este alvo
    if not predictionHistory[targetPart] then
        predictionHistory[targetPart] = {
            positions = {},
            velocities = {},
            timestamps = {},
            accelerations = {}
        }
    end
    
    local history = predictionHistory[targetPart]
    local now = tick()
    
    -- 2. ADICIONAR DADOS ATUAIS AO HISTÓRICO
    table.insert(history.positions, targetPart.Position)
    table.insert(history.velocities, targetVelocity)
    table.insert(history.timestamps, now)
    
    -- Manter apenas os últimos 10 frames
    if #history.positions > 10 then
        table.remove(history.positions, 1)
        table.remove(history.velocities, 1)
        table.remove(history.timestamps, 1)
    end
    
    -- 3. CALCULAR ACELERAÇÃO PRECISA
    local acceleration = Vector3.new(0, 0, 0)
    if #history.velocities >= 2 then
        local recentVel = history.velocities[#history.velocities]
        local previousVel = history.velocities[#history.velocities - 1]
        local timeDiff = history.timestamps[#history.timestamps] - history.timestamps[#history.timestamps - 1]
        
        if timeDiff > 0 then
            acceleration = (recentVel - previousVel) / timeDiff
            table.insert(history.accelerations, acceleration)
            
            -- Manter histórico de acelerações
            if #history.accelerations > 5 then
                table.remove(history.accelerations, 1)
            end
        end
    end
    
    -- 4. CALCULAR ACELERAÇÃO MÉDIA (suavizar flutuações)
    local avgAcceleration = Vector3.new(0, 0, 0)
    if #history.accelerations > 0 then
        for _, accel in ipairs(history.accelerations) do
            avgAcceleration = avgAcceleration + accel
        end
        avgAcceleration = avgAcceleration / #history.accelerations
    end
    
    -- 5. PREDIÇÃO BASE COM FÍSICA REAL
    local basePrediction = predictionMultiplier
    
    -- Fórmula física completa: S = S0 + V*t + (A*t²)/2
    local predictedPos = targetPart.Position + 
                        (targetVelocity * basePrediction) + 
                        (avgAcceleration * 0.5 * basePrediction * basePrediction)
    
    -- 6. DETECÇÃO DE PADRÕES DE MOVIMENTO
    if #history.positions >= 3 then
        -- Calcular tendência de movimento
        local recentPos = history.positions[#history.positions]
        local midPos = history.positions[#history.positions - 1]
        local oldPos = history.positions[#history.positions - 2]
        
        -- Vetores de movimento
        local recentMovement = recentPos - midPos
        local previousMovement = midPos - oldPos
        
        -- Detectar mudanças bruscas de direção
        local directionChange = recentMovement:Dot(previousMovement)
        local movementSimilarity = directionChange / (recentMovement.Magnitude * previousMovement.Magnitude + 0.001)
        
        -- Se está fazendo curva, ajustar predição
        if movementSimilarity < 0.7 then
            local curveIntensity = 1 - movementSimilarity
            local curveAdjustment = (recentMovement - previousMovement) * (basePrediction * curveIntensity * 0.5)
            predictedPos = predictedPos + curveAdjustment
        end
    end
    
    -- 7. PREDIÇÃO DE MOVIMENTOS CIRCULARES/ESQUIVAS
    if targetSpeed > 8 and #history.positions >= 5 then
        -- Analisar padrão de movimento dos últimos 5 frames
        local movementPattern = {}
        for i = 2, #history.positions do
            local movement = (history.positions[i] - history.positions[i-1]).Unit
            table.insert(movementPattern, movement)
        end
        
        -- Detectar movimento circular
        local circularScore = 0
        for i = 2, #movementPattern do
            local angle = movementPattern[i]:Dot(movementPattern[i-1])
            circularScore = circularScore + (1 - math.abs(angle))
        end
        
        -- Se detectado movimento circular, ajustar predição
        if circularScore > 2.5 then
            local circularAdjustment = (history.positions[#history.positions] - history.positions[1]).Unit * (basePrediction * 0.3)
            predictedPos = predictedPos + circularAdjustment
        end
    end
    
    -- 8. COMPENSAÇÃO DE LATÊNCIA DE REDE
    local ping = GetPing() / 1000 -- Converter para segundos
    local networkCompensation = ping * 0.5 -- Compensar 50% do ping
    predictedPos = predictedPos + (targetVelocity * networkCompensation)
    
    -- 9. PREDIÇÃO VERTICAL INTELIGENTE (para saltos/queda)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local gravity = workspace.Gravity / 196.2
        local verticalVelocity = targetVelocity.Y
        
        -- Se está caindo ou pulando
        if math.abs(verticalVelocity) > 5 then
            predictedPos = Vector3.new(
                predictedPos.X,
                predictedPos.Y + (verticalVelocity * basePrediction) + (gravity * 0.5 * basePrediction * basePrediction),
                predictedPos.Z
            )
        end
    end
    
    -- 10. SUAVIZAÇÃO FINAL DA PREDIÇÃO
    if history.lastPredictedPos then
        -- Suavizar transições entre predições
        local smoothFactor = 0.3
        predictedPos = history.lastPredictedPos:Lerp(predictedPos, smoothFactor)
    end
    
    history.lastPredictedPos = predictedPos
    
    return predictedPos
end

-- Adicione após as outras funções de predição
local function GetDynamicPredictionValue(targetPart)
    if not targetPart or not targetPart.Parent then
        return 0.15 -- Valor padrão aumentado
    end
    
    local rootPart = targetPart.Parent:FindFirstChild("HumanoidRootPart")
    if not rootPart then return 0.15 end
    
    local targetVelocity = rootPart.Velocity
    local targetSpeed = targetVelocity.Magnitude
    
    -- MAPEAMENTO BRUTAL PARA VELOCIDADES ALTAS
    if targetSpeed < 10 then
        -- Muito lento
        return 0.08
    elseif targetSpeed < 25 then
        -- Velocidade normal
        return 0.15
    elseif targetSpeed < 50 then
        -- Rápido
        return 0.25
    elseif targetSpeed < 80 then
        -- Muito rápido
        return 0.4
    elseif targetSpeed < 120 then
        -- Velocidade extrema
        return 0.6
    elseif targetSpeed < 200 then
        -- Hacks/teleport
        return 0.8
    else
        -- Velocidade impossível
        return 1.0
    end
end

-- SUBSTITUA pela versão corrigida:
local function GetSmartPrediction(targetPart, basePredictionMultiplier)
    -- SE AUTO-PREDICTION ESTÁ ATIVADO, IGNORAR basePredictionMultiplier
    if autoPredictionEnabled then
        local dynamicPrediction = GetDynamicPredictionValue(targetPart)
        return GetBrutalPrediction(targetPart, dynamicPrediction)
    end
    
    -- SE AUTO-PREDICTION DESATIVADO, usar valor manual (e verificar se é 0)
    if basePredictionMultiplier <= 0 then
        return targetPart.Position  -- Sem predição
    else
        return GetBrutalPrediction(targetPart, basePredictionMultiplier)
    end
end

-- FUNÇÃO PARA LIMPAR HISTÓRICO DE ALVOS REMOVIDOS
local function CleanPredictionHistory()
    for targetPart, history in pairs(predictionHistory) do
        if not targetPart or not targetPart.Parent then
            predictionHistory[targetPart] = nil
        end
    end
end


local aimbotConnection = nil
local function StartAimbot()
    if aimbotConnection then return end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then return end
        if not Camera or not Camera.CFrame then return end
        
        -- Limpar histórico periodicamente
        local now = tick()
        if now - lastPredictionUpdate > PREDICTION_UPDATE_RATE then
            CleanPredictionHistory()
            lastPredictionUpdate = now
        end
        
        if not currentTarget or not currentTarget.Parent then
            local player, part = GetBestTarget()
            if player then 
                currentTarget = part
            else
                currentTarget = nil
                return
            end
        end
        
        if currentTarget then
            -- USAR CONFIGURAÇÃO SALVA OU VALOR PADRÃO
            local predictionValue = settings.Prediction or 0.15
            local targetPos = GetSmartPrediction(currentTarget, predictionValue)
            
            Camera.CFrame = SmoothLookAt(Camera.CFrame, targetPos, settings.Smoothness)
        end
    end)
end

local function StopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    currentTarget = nil
end

local function ToggleAimbot(state)
    aimbotEnabled = state
    if aimbotEnabled then
        StartAimbot()
    else
        StopAimbot()
    end
end

local function MatchesInputToKey(input, chosenKey)
    if not input then return false end
    if chosenKey == "" then return false end
    
    if chosenKey == "MouseButton2" then
        return input.UserInputType == Enum.UserInputType.MouseButton2
    end
    
    if chosenKey == "LeftShift" then return input.KeyCode == Enum.KeyCode.LeftShift end
    if chosenKey == "RightShift" then return input.KeyCode == Enum.KeyCode.RightShift end
    
    local ok, kc = pcall(function() return Enum.KeyCode[chosenKey] end)
    if ok and kc then
        return input.KeyCode == kc
    end
    
    return false
end


