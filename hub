local function GetPing()
    local success, result = pcall(function()
        local stats = game:GetService("Stats")
        local perfStats = stats and stats:FindFirstChild("PerformanceStats")
        if perfStats then
            local pingStat = perfStats:FindFirstChild("Ping")
            if pingStat then
                return pingStat:GetValue()
            end
        end
        return 0
    end)
    
    return success and math.floor(result) or 0
end

