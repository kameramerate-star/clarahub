                    updateOverlayForPlayer(player)
                end)
                table.insert(overlayList[player].connections, stamina2Conn)
            else
                task.delay(1, function()
                    if overlayList[player] then
                        setupStamina2Listener()
                    end
                end)
            end
        end
        setupStamina2Listener()
    end
    
    -- Configurar listeners se o character já existe
    if player.Character then
        task.delay(0.5, function()
            if overlayList[player] then
                setupValueListeners(player.Character)
            end
        end)
    end
    
    -- Listener para quando o character é adicionado
    local characterAddedConn = player.CharacterAdded:Connect(function(character)
        task.wait(0.5) -- Esperar o character carregar completamente
        if overlayList[player] then
            setupValueListeners(character)
            updateOverlayForPlayer(player)
        end
    end)
    table.insert(overlayList[player].connections, characterAddedConn)
    
    -- Listener para quando o character é removido
    local characterRemovingConn = player.CharacterRemoving:Connect(function()
        -- Não limpar as conexões aqui, apenas atualizar display
        task.wait(0.1)
