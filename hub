    local function resort()
        local idx = 0
        for p, v in pairs(overlayList) do
            if p ~= Players.LocalPlayer then
                idx = idx + 1
                v.entry.Position = UDim2.new(0,0,0,(idx-1) * 32)
            end
        end
    end
    resort()
    
    return overlayList[player]
end

-- MODIFIQUE A FUNÇÃO removeOverlayEntry para ser mais segura
local function removeOverlayEntry(player)
    local e = overlayList[player]
    if e then
        -- Desconectar todas as conexões
        if e.connections then
            for _, conn in ipairs(e.connections) do
                if conn then
                    pcall(function() conn:Disconnect() end)
                end
            end
        end
        
        -- Remover a entry se ainda existir
        if e.entry and e.entry.Parent then 
            pcall(function() e.entry:Destroy() end)
        end
        overlayList[player] = nil
    end
    
    -- Reorganizar entradas restantes
    local function resort()
        local idx = 0
        for p, v in pairs(overlayList) do
            if p and p.Parent and p ~= Players.LocalPlayer then
                idx = idx + 1
                if v.entry and v.entry.Parent then
                    v.entry.Position = UDim2.new(0,0,0,(idx-1) * 32)
                end
            end
        end
    end
    resort()
end


local function cleanupInvalidOverlays()
    local toRemove = {}
    
    for player, entry in pairs(overlayList) do
        if not player or not player.Parent then
            table.insert(toRemove, player)
        elseif not entry.entry or not entry.entry.Parent then
            table.insert(toRemove, player)
        end
    end
    
    for _, player in ipairs(toRemove) do
        removeOverlayEntry(player)
    end
end

-- MODIFIQUE A FUNÇÃO updateOverlayForPlayer para prevenir o erro
local function updateOverlayForPlayer(player)
    if player == Players.LocalPlayer then return end
    
    -- Verificar se o player ainda é válido
    if not player or not player.Parent then
        removeOverlayEntry(player)
        return
    end
    
    local entry = overlayList[player]
    if not entry then 
        ensureOverlayEntry(player)
        return
    end
    
    -- Verificar se os componentes do entry ainda existem
    if not entry.entry or not entry.entry.Parent then
        removeOverlayEntry(player)
        ensureOverlayEntry(player)
        return
    end
    
    local char = player.Character
    if not char then
        if entry.healthLabel and entry.healthLabel.Parent then
            entry.healthLabel.Text = "0"
            entry.mdLabel.Text = "0"
            entry.staminaLabel.Text = "0"
            entry.stamina2Label.Text = "0"
            entry.healthLabel.TextColor3 = Color3.fromRGB(150,150,150)
            entry.mdLabel.TextColor3 = Color3.fromRGB(150,150,150)
            entry.staminaLabel.TextColor3 = Color3.fromRGB(150,150,150)
            entry.stamina2Label.TextColor3 = Color3.fromRGB(150,150,150)
        end
        return
    end
    
    local success, result = pcall(function()
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then 
            if entry.healthLabel and entry.healthLabel.Parent then
                entry.healthLabel.Text = "0"
                entry.mdLabel.Text = "0"
                entry.staminaLabel.Text = "0"
                entry.stamina2Label.Text = "0"
                entry.healthLabel.TextColor3 = Color3.fromRGB(150,150,150)
                entry.mdLabel.TextColor3 = Color3.fromRGB(150,150,150)
                entry.staminaLabel.TextColor3 = Color3.fromRGB(150,150,150)
                entry.stamina2Label.TextColor3 = Color3.fromRGB(150,150,150)
            end
            return
        end
        
        -- Verificar novamente se os labels existem antes de atualizar
        if not entry.healthLabel or not entry.healthLabel.Parent then
            return
        end
        
        -- Atualizar saúde
        local currentHealth = math.floor(hum.Health)
        entry.healthLabel.Text = tostring(currentHealth)
        
        local pct = math.clamp(hum.Health / math.max(1, hum.MaxHealth), 0, 1)
        if pct > 0.5 then
            entry.healthLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
        elseif pct > 0.3 then
            entry.healthLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
        else
            entry.healthLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
        
        -- Atualizar MD
        local mdValue = FindPlayerMDValue(player)
        if mdValue then
            local currentMD = mdValue.Value
            entry.mdLabel.Text = tostring(currentMD)
            entry.mdLabel.TextColor3 = Color3.fromRGB(180, 100, 255)
        else
            entry.mdLabel.Text = "0"
            entry.mdLabel.TextColor3 = Color3.fromRGB(150,150,150)
        end
        
        -- Atualizar Stamina
        local staminaValue = FindPlayerStaminaValue(player)
        if staminaValue then
            local currentStamina = staminaValue.Value
            entry.staminaLabel.Text = tostring(currentStamina)
            entry.staminaLabel.TextColor3 = Color3.fromRGB(100, 150, 255)
            
            if currentStamina and currentStamina < 30 then
                entry.staminaLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
        else
            entry.staminaLabel.Text = "0"
            entry.staminaLabel.TextColor3 = Color3.fromRGB(150,150,150)
        end
        
        -- Atualizar Stamina2
        local stamina2Value = FindPlayerStamina2Value(player)
        if stamina2Value then
            local currentStamina2 = stamina2Value.Value
            entry.stamina2Label.Text = tostring(currentStamina2)
            entry.stamina2Label.TextColor3 = Color3.fromRGB(255, 165, 0)
            
            if currentStamina2 and currentStamina2 < 30 then
                entry.stamina2Label.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
        else
            entry.stamina2Label.Text = "0"
            entry.stamina2Label.TextColor3 = Color3.fromRGB(150,150,150)
        end
    end)
    
    if not success then
        -- Em caso de erro, remover e recriar a entrada
        task.delay(1, function()
            if player and player.Parent then
                removeOverlayEntry(player)
                ensureOverlayEntry(player)
            end
        end)
    end
end



